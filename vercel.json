{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "NPM_CONFIG_PRODUCTION=false npm install",
  "buildCommand": "npm run build -w @investai/shared && npm run build -w @investai/frontend",
  "outputDirectory": "apps/frontend/dist",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
