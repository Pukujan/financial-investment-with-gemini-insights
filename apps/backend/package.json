{
  "name": "@investai/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:tiingo": "RUN_TIINGO_INTEGRATION=1 vitest run src/modules/market/services/__tests__/tiingo.live.test.ts",
    "test:yahoo": "RUN_YAHOO_INTEGRATION=1 vitest run src/modules/market/services/__tests__/yahoo.live.test.ts",
    "test:agent-eval": "RUN_AGENT_EVAL=1 vitest run src/modules/agent-scrape/services/eval/__tests__/evalRunner.live.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@investai/shared": "*",
    "@investai/prompts": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase": "^12.6.0",
    "yahoo-finance2": "^3.14.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
