# Copy to .env at repo root and fill in values:
#   cp .env.example .env

PORT=3001
CORS_ORIGIN=http://localhost:5173

# Demo gate — set both to require login (Railway + Vercel). Leave empty for open local dev.
DEMO_AUTH_USER=design-bakery
DEMO_AUTH_PASSWORD=design-bakery-3645
# DEMO_AUTH_SECRET=optional-signing-secret

# How many symbols to load on dashboard (0 = full catalog ~100). Default 100 = one Yahoo bulk refresh per cache window.
STOCK_FETCH_LIMIT=100

# Market: live = Yahoo Finance | mock = static catalog | agent = LLM chart scrape (OpenRouter)
MARKET_DATA_MODE=live

# Reuse live quotes/news for this many hours (12h default; browser localStorage uses same window). Refresh bypasses server RAM only.
MARKET_CACHE_TTL_HOURS=12

# Yahoo bulk fetch batching (rate-limit friendly)
MARKET_LIVE_BATCH_SIZE=3
MARKET_LIVE_BATCH_DELAY_MS=500

# Charts come from the daily stock preload (recommended). true = extra Yahoo API call per chart click.
LIVE_CHART_ON_DEMAND=false

# Prompt eval cooldown — anonymous: hours between runs; signed-in: minutes + daily cap
PROMPT_EVAL_COOLDOWN_HOURS=1
PROMPT_EVAL_AUTH_COOLDOWN_MINUTES=15
PROMPT_EVAL_AUTH_DAILY_MAX=5

# Agent scrape (MARKET_DATA_MODE=agent) — uses OpenRouter for 30-day chart JSON
AGENT_SCRAPE_SYMBOL_LIMIT=10
AGENT_SCRAPE_BATCH_SIZE=5
AGENT_SCRAPE_CHART_BATCH_SIZE=1
AGENT_SCRAPE_BATCH_DELAY_MS=300
AGENT_SCRAPE_BATCH_TIMEOUT_MS=90000
AGENT_SCRAPE_JOB_TIMEOUT_MS=300000
AGENT_SCRAPE_MAX_BATCH_RETRIES=1
# Inject RAG catalog/news context into chart scrape prompts (default true; set false to disable)
AGENT_SCRAPE_RAG=true
# Strong vs weaker cheap models for scrape + golden eval
# AI cost tiers for estimates + agent scrape (cheapest → cheap, all paid)
AI_TIER_CHEAPEST=qwen/qwen3.5-flash-02-23
AI_TIER_CHEAPER=google/gemini-2.0-flash-001
AI_TIER_CHEAP=deepseek/deepseek-chat-v3-0324

# Optional overrides for agent golden eval
# AGENT_MODEL_STRONG=deepseek/deepseek-chat-v3-0324
# AGENT_MODEL_WEAK=qwen/qwen3.5-flash-02-23

# Required for AI features (get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Paid defaults — DeepSeek V3 (primary) + Qwen 3.5 Flash (fallback). See openrouter.ai/models
OPENROUTER_MODEL_PRIMARY=deepseek/deepseek-chat-v3-0324
OPENROUTER_MODEL_FALLBACK=qwen/qwen3.5-flash-02-23

# Firebase (portfolio + AI cache) — optional but recommended
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_APP_INSTANCE_ID=financial-app

# Frontend — OPTIONAL
# Dev: leave empty. Vite proxies /api → http://localhost:${PORT}
# Production: set to your deployed API, e.g. https://api.yourapp.com
# Dev: leave empty — Vite proxies /api → backend (see PORT).
# Vercel: set to your Railway API origin, e.g. https://your-service.up.railway.app (no trailing slash).
VITE_API_URL=
